---
const { title } = Astro.props;
import '../assets/styles/global.css';
---

<!doctype html>
<html lang="ja">
		<head>
				<meta charset="UTF-8" />
				<meta name="viewport" content="width=device-width, initial-scale=1.0" />
				<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
				<link rel="icon" href="/favicon.ico" />

				<link rel="preconnect" href="https://fonts.googleapis.com" />
				<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
				<link
					href="https://fonts.googleapis.com/css2?family=Barlow:wght@500;700;800&family=Noto+Sans+JP:wght@400;500;700&display=swap"
					rel="stylesheet"
				/>

				<title>{title || "Toyama Univ. MR Project"}</title>
				<meta
					name="description"
					content="富山大学MRプロジェクトの紹介サイト。Mixed Realityに関する研究・開発・お知らせを発信します。"
				/>
		</head>
		<body>
				<slot />
				<script src="/src/assets/script/script.js"></script>
		</body>
</html>
